---
import Layout from '../layouts/Layout.astro';

const title = 'Abbika - AI-Powered Mobile Apps & Web3 Innovation Startup';
const description = 'Abbika builds VerbPal, an AI-powered language learning app for children, and TaskJogger, an intelligent task management platform. Pre-funded startup developing breakthrough EdTech, productivity, and blockchain security products.';
---

<Layout title={title} description={description}>

  <!-- Header -->
  <header class="site-header" role="banner">
    <div class="header-inner">
      <div class="site-logo">
        <a href="/" aria-label="Abbika - Home">
          <img src="/one-page/images/logo.png" alt="Abbika Logo" width="160" height="48" loading="eager" />
        </a>
      </div>

      <button class="mobile-menu-toggle" aria-label="Toggle navigation menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>

      <nav class="site-nav" role="navigation" aria-label="Main navigation">
        <a href="#top">Home</a>
        <a href="#about">About</a>
        <a href="#products">Products</a>
        <a href="#vision">Vision</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>
  </header>

  <main id="top">

    <!-- Hero Section -->
    <section class="hero-section" aria-label="Introduction">
      <div class="hero-content">
        <div class="hero-inner">
          <span class="hero-badge">AI & Web3 Innovation</span>
          <h1 class="hero-title">
            Building the Future of <strong>AI Mobile Apps</strong> & <strong>Web3</strong>
          </h1>
          <p class="hero-subtitle">
            Creators of <a href="https://www.verbpal.com" class="hero-product-link">VerbPal</a> and <a href="https://www.taskjogger.com" class="hero-product-link">TaskJogger</a> — developing revolutionary AI-powered apps and next-generation Web3 tools. From idea to IPO, we're building tomorrow's essential technologies today.
          </p>
          <a href="#about" class="btn-modern">
            Learn About Our Vision
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Mission Bridge -->
    <div class="mission-bridge-wrapper">
      <div class="mission-bridge-inner">
        <div class="mission-bridge">
          <p>
            At Abbika, our mission is to build technology that <strong>empowers and protects</strong>. Through products like <a href="https://www.verbpal.com">VerbPal</a> and <a href="https://www.taskjogger.com">TaskJogger</a>, we focus on AI-powered apps that enrich minds and boost productivity, alongside next-generation Web3 tools that safeguard digital assets. These sectors are united by a single belief: that thoughtful innovation can shape a safer, smarter, and more meaningful digital future for all.
          </p>
        </div>
      </div>
    </div>

    <!-- Mission Cards -->
    <div class="section-container">
      <div class="cards-grid">
        <article class="modern-card">
          <div class="card-content">
            <span class="card-badge">Our Mission</span>
            <h2 class="card-title">Revolutionizing Education & Blockchain Security</h2>
            <p class="card-text">We're building breakthrough AI mobile applications like <a href="https://www.verbpal.com">VerbPal</a> that transform how children learn languages through immersive storytelling, productivity tools like <a href="https://www.taskjogger.com">TaskJogger</a>, and cutting-edge Web3 tools that will revolutionize smart contract security auditing.</p>
          </div>
        </article>
        <article class="modern-card">
          <div class="card-content">
            <span class="card-badge">Startup DNA</span>
            <h2 class="card-title">Pre-Funded & Ready to Scale</h2>
            <p class="card-text">We're a true product startup with significant investment in proprietary technology. Our pre-seed funding and strategic partnerships provide runway capital while we develop game-changing products that will define the future of their respective markets.</p>
          </div>
        </article>
      </div>
    </div>

    <!-- About Section -->
    <section id="about" class="about-section" aria-label="About Abbika">
      <div class="section-container">
        <div class="section-header">
          <h2 class="section-title">A Technology Startup Built for Tomorrow's Markets</h2>
        </div>
        <div class="about-content">
          <p class="about-text">We're not just another software company — we're a pre-funded startup with a clear vision to transform massive markets. With products like <a href="https://www.verbpal.com">VerbPal</a> (AI-powered language learning for children) and <a href="https://www.taskjogger.com">TaskJogger</a> (intelligent task management), plus our Web3 security tools, we're focused on developing revolutionary products that capture significant market share.</p>
          <p class="about-text">Our current products represent just the beginning of an ambitious roadmap. With additional breakthrough concepts in development, we're positioning ourselves as the go-to startup for AI mobile applications, productivity tools, and Web3 security solutions.</p>
          <a href="#products" class="about-link">
            Explore Our Products
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Products Section -->
    <section id="products" class="products-section" aria-label="Our Products">
      <div class="section-container">
        <div class="section-header">
          <h2 class="section-title">Revolutionary Products in Development</h2>
          <p class="section-subtitle">Our MVP Portfolio</p>
        </div>

        <div class="products-grid">
          <article class="product-card">
            <div class="product-icon">
              <i class="icon-et-mobile" aria-hidden="true"></i>
            </div>
            <h3 class="product-title"><a href="https://www.verbpal.com" class="product-link">VerbPal</a> — AI Language Learning Through Stories</h3>
            <p class="product-description">
              <strong>Target Market:</strong> Educational Technology / Children's Apps<br /><br />
              <a href="https://www.verbpal.com">VerbPal</a> is our flagship mobile application combining AI-powered storytelling with immersive language learning. Children learn Spanish (and other languages) through personalized bedtime stories, with "choose your own adventure" elements that make learning engaging and memorable. This represents a $60+ billion global market opportunity in educational technology.
            </p>
            <a href="https://www.verbpal.com" class="product-cta">
              Visit VerbPal
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
            </a>
          </article>

          <article class="product-card">
            <div class="product-icon">
              <i class="icon-et-shield" aria-hidden="true"></i>
            </div>
            <h3 class="product-title"><a href="https://www.taskjogger.com" class="product-link">TaskJogger</a> — Intelligent Task Management</h3>
            <p class="product-description">
              <strong>Target Market:</strong> Productivity / Task Management<br /><br />
              <a href="https://www.taskjogger.com">TaskJogger</a> is our AI-powered task management platform designed to help teams and individuals stay organized, prioritize effectively, and accomplish more. Built with intelligent automation at its core, TaskJogger transforms how people manage their daily workflows and long-term goals.
            </p>
            <a href="https://www.taskjogger.com" class="product-cta">
              Visit TaskJogger
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
            </a>
          </article>
        </div>

        <div class="pipeline-callout">
          <h4>Additional Innovations in Pipeline</h4>
          <p class="section-subtitle">Beyond our current MVPs, we have 3-4 additional breakthrough concepts in AI mobile applications that will be unveiled as we secure VC funding and expand our development team. Each product is designed to capture significant market share in high-growth technology sectors.</p>
        </div>
      </div>
    </section>

    <!-- Vision Section -->
    <section id="vision" class="vision-section" aria-label="Growth Strategy">
      <div class="section-container">
        <div class="vision-layout">
          <div>
            <div class="section-header text-start" style="margin-bottom: 0;">
              <h2 class="section-title">Our Growth Strategy & VC Journey</h2>
            </div>
          </div>
          <div>
            <div class="vision-grid">
              <article class="vision-card">
                <h4 class="vision-title">
                  <i class="icon-et-target vision-icon" aria-hidden="true"></i>
                  Phase 1: MVP Validation
                </h4>
                <p class="vision-text">Launching <a href="https://www.verbpal.com">VerbPal</a> and <a href="https://www.taskjogger.com">TaskJogger</a> to market. Demonstrating product-market fit and establishing initial user bases across both platforms.</p>
              </article>

              <article class="vision-card">
                <h4 class="vision-title">
                  <i class="icon-et-strategy vision-icon" aria-hidden="true"></i>
                  Phase 2: Market Penetration
                </h4>
                <p class="vision-text">Scaling user acquisition, forming strategic partnerships with educational institutions and Web3 security firms. Revenue validation across both product lines.</p>
              </article>

              <article class="vision-card">
                <h4 class="vision-title">
                  <i class="icon-et-trophy vision-icon" aria-hidden="true"></i>
                  Phase 3: VC Funding
                </h4>
                <p class="vision-text">Series A funding round to accelerate growth, expand team, and launch additional AI mobile app concepts. Target: $5M-$15M based on traction metrics.</p>
              </article>

              <article class="vision-card">
                <h4 class="vision-title">
                  <i class="icon-et-hotairballoon vision-icon" aria-hidden="true"></i>
                  Phase 4: Market Leadership
                </h4>
                <p class="vision-text">Establishing market-leading positions in both EdTech and Web3 security. Preparing for additional funding rounds and potential acquisition opportunities.</p>
              </article>
            </div>

            <div class="consulting-callout">
              <h5>Bootstrap to Scale: Our Funding Strategy</h5>
              <p>We've strategically bootstrapped our operations through initial funding and strategic partnerships, allowing us to remain focused on product development while building revolutionary technologies. This approach enables us to demonstrate strong product-market fit before pursuing institutional investment rounds.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer id="contact" class="site-footer" role="contentinfo">
    <div class="footer-inner">
      <div class="footer-grid">
        <div>
          <h4 class="footer-title">Company</h4>
          <nav aria-label="Footer navigation">
            <a href="#about" class="footer-link">About Our Startup</a>
            <a href="#products" class="footer-link">Our Products</a>
            <a href="#vision" class="footer-link">Growth Strategy</a>
            <a href="#contact" class="footer-link">Contact</a>
          </nav>
        </div>

        <div>
          <h4 class="footer-title">Our Products</h4>
          <nav aria-label="Product links">
            <a href="https://www.verbpal.com" class="footer-link" rel="noopener">VerbPal — AI Language Learning</a>
            <a href="https://www.taskjogger.com" class="footer-link" rel="noopener">TaskJogger — Smart Task Management</a>
          </nav>

          <h4 class="footer-title" style="margin-top: 28px;">Investor Relations</h4>
          <p style="font-size: 14px; color: rgba(255, 255, 255, 0.7); margin-bottom: 16px;">
            Interested in funding opportunities or strategic partnerships?
          </p>
          <a href="mailto:investors@abbika.com" class="footer-email">investors@abbika.com</a>
        </div>

        <div>
          <h4 class="footer-title">Contact</h4>
          <address style="color: rgba(255, 255, 255, 0.9); line-height: 1.8; font-style: normal;">
            <strong>Abbika LLC</strong><br />
            <strong>General:</strong> <a href="mailto:info@abbika.com" class="footer-email">info@abbika.com</a><br />
            <strong>Partnerships:</strong> <a href="mailto:partnerships@abbika.com" class="footer-email">partnerships@abbika.com</a>
          </address>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span>&copy; {new Date().getFullYear()} Abbika LLC | AI-Powered Innovation | Pre-Funded Startup</span>
    </div>
  </footer>

  <!-- Back to Top -->
  <button class="back-to-top" aria-label="Back to top">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>

</Layout>
